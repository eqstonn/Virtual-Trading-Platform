{
  "name": "virtual-trading-platform",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently \"cd frontend && npm run dev\" \"cd backend && uvicorn app_api:app --reload\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && uvicorn app_api:app --reload",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
